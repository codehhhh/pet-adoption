<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kmbeast.mapper.WarningRuleMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.kmbeast.pojo.entity.WarningRule">
        <id column="id" property="id"/>
        <result column="rule_name" property="ruleName"/>
        <result column="condition_desc" property="conditionDesc"/>
        <result column="min_score" property="minScore"/>
        <result column="max_score" property="maxScore"/>
        <result column="warning_level" property="warningLevel"/>
        <result column="action" property="action"/>
        <result column="is_active" property="isActive"/>
    </resultMap>

    <!-- 获取所有启用的规则 -->
    <select id="selectAllActive" resultMap="BaseResultMap">
        SELECT * FROM warning_rule
        WHERE is_active = 1
        ORDER BY warning_level DESC
    </select>

    <!-- 根据分数获取匹配的规则 -->
    <select id="selectByScore" parameterType="int" resultMap="BaseResultMap">
        SELECT * FROM warning_rule
        WHERE is_active = 1
          AND min_score &lt;= #{score}
          AND (max_score >= #{score} OR max_score IS NULL)
        ORDER BY warning_level DESC
            LIMIT 1
    </select>
</mapper>